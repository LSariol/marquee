# Database — your existing Postgres instance (server: sparkdb, database: marquee)
MARQUEE_MIGRATOR_DATABASE_URL=postgres://marquee_migrator:<password>@sparkdb:5432/marquee?sslmode=disable
MARQUEE_APP_DATABASE_URL=postgres://marquee_app:<password>@sparkdb:5432/marquee?sslmode=disable

# App
MARQUEE_PORT=3051
MARQUEE_BASE_URL=http://localhost:3051
MARQUEE_SESSION_SECRET=replace-with-32+-random-bytes-here-at-least-32
MARQUEE_OWNER_TWITCH_ID=42217464

# Twitch — https://dev.twitch.tv/console/apps
MARQUEE_TWITCH_CLIENT_ID=
MARQUEE_TWITCH_CLIENT_SECRET=

# TMDB — https://www.themoviedb.org/settings/api
MARQUEE_TMDB_API_KEY=
